{
  "tenant-mode": "dedicated",
  "xsappname": "banking_capm",
  "scopes": [
    {
      "name": "$XSAPPNAME.Customer",
      "description": "Banking Customer"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Banking Admin"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "Admin",
      "description": "Banking Admin",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    },
    {
      "name": "Customer",
      "description": "Banking Customer",
      "scope-references": [
        "$XSAPPNAME.Customer"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "BankingCustomer",
      "description": "Customer Role for customer_banking app",
      "role-template-references": ["$XSAPPNAME.Customer"]
    },
    {
      "name": "BankingAdmin",
      "description": "Admin Role for customer_banking",
      "role-template-references": ["$XSAPPNAME.Admin"]
    }
  ],
  "authorities-inheritance": false,
  "oauth2-configuration": {
    "redirectUris": [
      "http://localhost:4004/**",
      "https://*.trial.applicationstudio.cloud.sap/**",
      "https://*.cfapps.us10-001.hana.ondemand.com/**",
      "https://*.cf.us10-001.hana.ondemand.com/**"
    ]
  }
}
