<mvc:View 
    controllerName="customerbanking.controller.Account_List"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="_IDGenPage1" title="My Accounts" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <List
                id="accountList"
                items="{accountsModel>/accounts}"
                mode="SingleSelectMaster"
                selectionChange="onAccountSelected">
                
                <StandardListItem id="_IDGenStandardListItem"
                    title="Account Number: {path: 'accountsModel>account_no',type: 'sap.ui.model.type.String'}"
                    description="Type: {accountsModel>type}"
                    type="Navigation"/>
            </List>
        </content>
    </Page>
</mvc:View>