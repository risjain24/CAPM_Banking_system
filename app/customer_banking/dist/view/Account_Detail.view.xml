<mvc:View 
    xmlns:form="sap.ui.layout.form"
    controllerName="customerbanking.controller.Account_Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="_IDGenPage" title="Account Details" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox id="_IDGenVBox1" class="sapUiMediumMargin">

                <!-- Account Info -->
                <Panel id="_IDGenPanel1" headerText="Account Info">
                    <content>
                        <form:SimpleForm id="_IDGenSimpleForm">
                            <Label id="_IDGenLabel3" text="Type"/>
                            <Text id="accountType" text="{account>/type}"/>
                            <Label id="_IDGenLabel4" text="Balance"/>
                            <Text id="accountBalance" text="{account>/balance}"/>
                            <Label id="_IDGenLabel5" text="Account Number"/>
                            <Text id="accountNumber" text="{account>/account_no}"/>
                            <Label id="_IDGenLabel6" text="IFSC Code"/>
                            <Text id="ifscCode" text="{account>/ifsc_code}"/>
                        </form:SimpleForm>
                    </content>
                </Panel>

                <!-- Action Buttons -->
                <HBox id="_IDGenHBox" class="sapUiMediumMarginTop" justifyContent="SpaceBetween">
                    <Button id="_IDGenButton2" text="Deposit"  type="Success" press="onDeposit"/>
                    <Button id="_IDGenButton3" text="Withdraw" type="Negative" press="onWithdraw"/>
                    <Button id="_IDGenButton4" text="Transfer" type="Emphasized" press="onTransfer"/>
                </HBox>

                <!-- Navigate to Transactions -->
                <Button id="_IDGenButton5"
                    text="View Transactions"
                    press="onNavToTransactions"
                    class="sapUiMediumMarginTop"/>

            </VBox>
        </content>
    </Page>
</mvc:View>