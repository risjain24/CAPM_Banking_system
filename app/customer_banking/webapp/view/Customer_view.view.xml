<mvc:View 
    xmlns:form="sap.ui.layout.form" 
    controllerName="customerbanking.controller.Customer_view"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <headerContent>
            <Toolbar id="_IDGenToolbar1">
                <ToolbarSpacer id="_IDGenToolbarSpacer"/>
                <Button
                    id="editBtn"
                    text="Edit"
                    icon="sap-icon://edit"
                    press="onEdit"/>
                <Button
                    id="saveBtn"
                    text="Save"
                    icon="sap-icon://save"
                    type="Emphasized"
                    press="onSave"
                    visible="false"/>
            </Toolbar>
        </headerContent>
        <content>
            <VBox id="_IDGenVBox" class="sapUIMediumMargin">
                <Panel id="_IDGenPanel" headerText="Personal Details">
                    <content>
                        <form:SimpleForm id="_IDGenSimpleForm1" >
                            <Label id="_IDGenLabel" text="Name"/>
                            <Input id="customerName" value="{profile>/name}" editable="false"/>
                            <Label id="_IDGenLabel1" text="Email"/>
                            <Input id="customerEmail" value="{profile>/email}" editable="false"/>
                            <Label id="_IDGenLabel2" text="Phone"/>
                            <Input id="customerPhone" value="{profile>/phone}" editable="false"/>
                            <Label id="_IDGenLabel7" text="Address"/>
                            <Input id="customerAddress" value="{profile>/address}" editable="false"/>
                        </form:SimpleForm>
                    </content>
                </Panel>

                <Button id="_IDGenButton"
                    text="View My Accounts"
                    type="Emphasized"
                    press="onNavToAccounts"
                    class="sapUIMediumMarginTop" />
                
                <Button id="_IDGenButton1"
                    text="Add Beneficiary"
                    icon="sap-icon://add-contact"
                    press="onAddBeneficiary"
                    class="sapUiMediumMarginTop"/>
            </VBox>
        </content>
    </Page>
</mvc:View>