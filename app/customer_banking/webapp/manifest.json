{
  "_version": "1.83.0",
  "sap.app": {
    "id": "customerbanking",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "4c476029-1b4d-48a2-b8a4-d724ff0679ad"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/banking/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "customer_banking-display": {
          "semanticObject": "customer_banking",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "customerbanking.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "customerbanking.view",
        "async": true
      },
      "routes": [
        {
          "name": "RouteCustomer_view",
          "pattern": ":?query:",
          "target": [
            "TargetCustomer_view"
          ]
        },
        {
          "name": "RouteAccountList",
          "pattern": "accounts",
          "target": "accountList"
        },
        {
          "name": "RouteAccountDetail",
          "pattern": "accounts/{accountId}",
          "target": "accountDetail"
        },
        {
          "name": "RouteTransactionList",
          "pattern": "accounts/{accountId}/transactions",
          "target": "transactionList"
        }
      ],
      "targets": {
        "TargetCustomer_view": {
          "id": "Customer_view",
          "name": "Customer_view"
        },
        "accountList": {
          "id": "Account_List",
          "name": "Account_List"
        },
        "accountDetail": {
          "id": "Account_Detail",
          "name": "Account_Detail"
        },
        "transactionList": {
          "id": "Transaction_List",
          "name": "Transaction_List"
        }
      }
    },
    "rootView": {
      "viewName": "customerbanking.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "banking_capm"
  }
}
